# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Virtual Environment ---
venv/
.venv/
env/
ENV/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/

# --- Output data (keep folder structure, ignore generated files) ---
output/*.csv
output/*.json
output/*.txt
output/*.html
output/*.png
# Keep the folder itself tracked via .gitkeep
!output/.gitkeep

# --- IDEs & Editors ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Misc ---
*.log
.env
